                                            <span t-esc="str(photo.mars_sequence).zfill(2)"/>.
                                        </div>
                                        
                                        <div style="height: 140px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                                            <img t-att-src="image_data_uri(photo.image)" style="max-height: 130px; max-width: 100%;"/>
                                        </div>
                                        
                                        <div style="font-weight: bold; font-size: 12px; margin-top: 10px;">
                                            <span t-field="photo.subtitle"/>
                                        </div>
                                        
                                    </div>
                                </t>
                            </div>

                            <div style="position: absolute; bottom: 15mm; left: 20mm; right: 20mm; border-top: 3px solid black; padding-top: 10px;">
                                <table style="width: 100%; font-size: 12px;">
                                    <tbody>
                                        <tr>
                                            <td style="text-align: left; width: 38%;">proyectos@marsperu.com</td>
                                            <td style="text-align: center; width: 32%;">www.marsperu.com</td>
                                            <td style="text-align: right; width: 30%;">+51 936830534</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </t>

                <t t-foreach="doc.mars_acta_ids" t-as="acta">
