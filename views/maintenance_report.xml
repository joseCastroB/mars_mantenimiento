                <t t-foreach="doc.mars_gancho_ids" t-as="gancho">
                    <div class="pagina-interna" t-translation="off">
                        <div class="contenido-margen">
                            
                            <div style="width: 100%; border-bottom: 4px solid black; padding-bottom: 10px; margin-bottom: 20px;">
                                <table style="width: 100%;">
                                    <tbody>
                                        <tr>
                                            <td style="text-align: left; width: 33%;"><img src="http://127.0.0.1:8069/mars_mantenimiento/static/src/img/logo_donati.png" style="height: 35px;"/></td>
                                            <td style="text-align: center; width: 33%;"><img src="http://127.0.0.1:8069/mars_mantenimiento/static/src/img/logo_demag.png" style="height: 35px;"/></td>
                                            <td style="text-align: right; width: 50%;"><img src="http://127.0.0.1:8069/mars_mantenimiento/static/src/img/logo_mars.png" style="height: 90px;"/></td>
