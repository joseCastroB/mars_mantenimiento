                                            <td style="text-align: center; width: 32%;">www.marsperu.com</td>
                                            <td style="text-align: right; width: 30%;">+51 936830534</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>

                    <t t-set="equip_photos" t-value="doc.mars_photo_ids.filtered(lambda p: p.equipment_id.id == equipment.id)"/>
                    
                    <div class="pagina-interna" style="page-break-before: always;" t-translation="off" t-if="equip_photos">
                        <div class="contenido-margen">
                            
                            <div style="width: 100%; border-bottom: 4px solid black; padding-bottom: 10px; margin-bottom: 20px;">
                                <table style="width: 100%;">
                                    <tbody>
                                        <tr>
                                            <td style="text-align: left; width: 33%;"><img src="http://127.0.0.1:8069/mars_mantenimiento/static/src/img/logo_donati.png" style="height: 35px;"/></td>
                                            <td style="text-align: center; width: 33%;"><img src="http://127.0.0.1:8069/mars_mantenimiento/static/src/img/logo_demag.png" style="height: 35px;"/></td>
                                            <td style="text-align: right; width: 50%;"><img src="http://127.0.0.1:8069/mars_mantenimiento/static/src/img/logo_mars.png" style="height: 90px;"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <div style="font-weight: bold; margin-bottom: 15px; text-transform: uppercase;">1. REGISTRO FOTOGRAFICO</div>

                            <div style="width: 100%;">
                                <t t-foreach="equip_photos" t-as="photo">
                                    <div style="float: left; width: 50%; border: 1px solid black; padding: 10px; text-align: center; height: 230px; box-sizing: border-box;">
                                        
